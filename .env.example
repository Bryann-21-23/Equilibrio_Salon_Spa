# Archivo de ejemplo de variables de entorno (no modificar)
# Copia este archivo a un nuevo archivo llamado .env y completa los valores.

# URL de tu proyecto de Supabase (ej: https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=TU_SUPABASE_URL

# Clave pública anónima de tu proyecto de Supabase (Anon Key)
SUPABASE_KEY=TU_SUPABASE_ANON_KEY
